<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="smmg">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import smmg urdf file -->
    <xacro:include filename="$(find smmg)/urdf/smmg.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="smmg.ros2_control.xacro" />


    <xacro:smmg_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
